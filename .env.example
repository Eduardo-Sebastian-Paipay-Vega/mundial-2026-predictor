# ============================================================
# Mundial 2026 Predictor -- Plantilla de variables de entorno
# ============================================================
# Copiar este archivo como .env y completar los valores reales.
# El archivo .env NUNCA debe subirse al repositorio.
# ============================================================

# -- APIs de datos deportivos ---------------------------------------------------
# Football-Data.org: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_key_here

# OpenWeatherMap: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_key_here

# NOAA CDO (opcional): https://www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=your_token_here

# -- Configuracion de la aplicacion --------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development

# -- Directorio de datos (relativo a la raiz del proyecto) ---------------------
DATA_DIR=./data

# -- Periodo de datos historicos -----------------------------------------------
START_YEAR=2017
END_YEAR=2025

# -- Delay entre requests de scraping (segundos) -------------------------------
SCRAPE_DELAY=1.5
